# WhatsApp Bot Configuration

# =========================
# Twilio Configuration
# =========================
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your WhatsApp Business Phone Number (with country code)
# Format: whatsapp:+1234567890
TWILIO_PHONE_NUMBER=whatsapp:+14155552671

# =========================
# Server Configuration
# =========================
# Server port
PORT=3000

# Environment: development, production
NODE_ENV=development

# =========================
# Database Configuration
# =========================
# Path to SQLite database file
DB_PATH=./data/bot.db

# =========================
# Admin & Security
# =========================
# Admin API password/token
# Use a strong, random password
ADMIN_PASSWORD=your_very_secure_password_here_min_16_chars

# Admin phone number for direct commands
ADMIN_PHONE=whatsapp:+1234567890

# =========================
# File Upload Configuration
# =========================
# Maximum file size in bytes (5MB default)
MAX_FILE_SIZE=5242880

# Directory to store uploaded images
UPLOAD_DIR=./uploads

# =========================
# Feature Flags
# =========================
# Enable/disable features
ENABLE_BULK_MESSAGING=true
ENABLE_AUTO_REPLY=true
ENABLE_IMAGE_HANDLING=true
ENABLE_UPDATES_BROADCAST=true

# =========================
# Subscription Settings
# =========================
# Default subscription period in days
DEFAULT_SUBSCRIPTION_DAYS=30

# Days before expiry to send reminder
REMINDER_DAYS_BEFORE=7

# =========================
# Rate Limiting
# =========================
# Delay between bulk messages (milliseconds)
# Adjust based on Twilio limits
BULK_MESSAGE_DELAY_MS=100

# =========================
# Optional: Payment Integration
# =========================
# For future payment gateway integration
# STRIPE_API_KEY=sk_live_xxxx
# PAYPAL_CLIENT_ID=xxxxxx
# PAYPAL_SECRET=xxxxxx

# =========================
# Optional: Analytics
# =========================
# Google Analytics or other tracking
# ANALYTICS_ID=xxxx

# =========================
# Optional: Email Notifications
# =========================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=admin@example.com

# =========================
# Optional: Logging
# =========================
# LOG_LEVEL=info (debug, info, warn, error)
# LOG_FILE=./logs/bot.log
